# Copy to jem/.env for local runs — never commit .env
# ANTHROPIC_API_KEY is required only for fetcher/verifier agents (Session 4A).
# REST entity search and MCP tools work without it.

ANTHROPIC_API_KEY=
JEM_DB_PATH=data/jem.db
JEM_AUTH_MODE=dev
JEM_SESSION_SECRET=change-me-in-production
# Must match the host/port you run uvicorn on (redirect URI is derived from this).
JEM_BASE_URL=http://127.0.0.1:8001
# Comma-separated origins for map + API (include production host when deployed)
# JEM_CORS_ORIGINS=http://localhost:8080,https://friedso.com,https://www.friedso.com
# Map UI URL for chrome links on API satellite pages (admin, portal, docs, MCP)
# JEM_MAP_URL=http://127.0.0.1:8080
# Production: JEM_MAP_URL=https://friedso.com/apps/jem

# LinkedIn Sign In with OpenID Connect — see docs/AUTH_SETUP.md
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Comma-separated LinkedIn oauth `sub` values granted maintainer on first login
# JEM_MAINTAINER_OAUTH_SUBS=

#!/usr/bin/env bash
set -euo pipefail
REPO_ROOT="$(git rev-parse --show-toplevel)"
JEM="$REPO_ROOT/jem"
STAGED="$(git diff --cached --name-only -- 'jem/data/' 2>/dev/null || true)"
[[ -z "$STAGED" ]] && exit 0
echo "pre-commit: JEM data changed — running validate --strict"
(cd "$JEM" && python3 scripts/validate.py --strict) || exit 1
